{
    "name": "@opra-frontend/react-toolkit",
    "version": "1.0.0",
    "description": "React toolkit for consuming OPRA schemas with React Query and Redux Toolkit integration.",
    "type": "module",
    "files": [
        "dist",
        "README.md"
    ],
    "main": "./dist/core/index.js",
    "module": "./dist/core/index.mjs",
    "types": "./dist/core/index.d.ts",
    "exports": {
        "./core": {
            "import": "./dist/core/index.mjs",
            "require": "./dist/core/index.js",
            "types": "./dist/core/index.d.ts"
        },
        "./react-query": {
            "import": "./dist/react-query/index.mjs",
            "require": "./dist/react-query/index.js",
            "types": "./dist/react-query/index.d.ts"
        },
        "./rtk": {
            "import": "./dist/rtk/index.mjs",
            "require": "./dist/rtk/index.js",
            "types": "./dist/rtk/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "eslint \"src/**/*.{ts,tsx}\"",
        "format": "prettier --write \"src/**/*.{ts,tsx}\"",
        "prepublishOnly": "yarn lint && yarn format && yarn build"
    },
    "peerDependencies": {
        "@reduxjs/toolkit": "^2.0.0",
        "@tanstack/react-query": "^5.0.0",
        "react": "^18.0.0",
        "react-redux": "^9.0.0"
    },
    "peerDependenciesMeta": {
        "@reduxjs/toolkit": {
            "optional": true
        },
        "@tanstack/react-query": {
            "optional": true
        },
        "react-redux": {
            "optional": true
        }
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@reduxjs/toolkit": "^2.12.0",
        "@tanstack/react-query": "^5.100.14",
        "@types/react": "^19.2.15",
        "eslint": "^9.0.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "prettier": "^3.0.0",
        "react": "^19.2.6",
        "react-redux": "^9.3.0",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^7.0.0"
    }
}
